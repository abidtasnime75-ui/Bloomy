import 'package:flutter/material.dart';
import '../widgets/confirm_dialog.dart';
import '../utils/constants.dart';

class ControlScreen extends StatefulWidget {  // ✅ Classe publique (pas de _)
  const ControlScreen({super.key});
  
  @override
  State<ControlScreen> createState() => _ControlScreenState();
}

class _ControlScreenState extends State<ControlScreen> {
  bool pumpOn = false, fanOn = false, ledOn = false, vacationMode = false;
  
  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('← Contrôle Manuel'),
        leading: IconButton(icon: const Icon(Icons.arrow_back), onPressed: () => Navigator.pop(context)),
      ),
      body: SingleChildScrollView(
        padding: const EdgeInsets.all(16),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.stretch,
          children: [
            Text('Activez les actionneurs manuellement', style: TextStyle(fontSize: 15, color: Colors.grey[600])),
            const SizedBox(height: 24),
            
            // 💧 Pompe
            _buildSectionTitle('💧 POMPE D\'ARROSAGE'),
            Card(
              child: Padding(
                padding: const EdgeInsets.all(16),
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Text('État actuel : ${pumpOn ? '✅ ON' : '❌ OFF'}', style: const TextStyle(fontWeight: FontWeight.w500)),
                    const SizedBox(height: 8),
                    _buildDetailRow('Durée', '10 secondes'),
                    _buildDetailRow('Consommation', '~5W'),
                    const SizedBox(height: 16),
                    ElevatedButton(
                      onPressed: () => _confirmPump(),
                      style: ElevatedButton.styleFrom(
                        backgroundColor: pumpOn ? Colors.red : Colors.blue,
                        foregroundColor: Colors.white,
                      ),
                      child: Text(pumpOn ? 'DÉSACTIVER' : 'ACTIVER MANUELLEMENT'),
                    ),
                    if (!pumpOn) Padding(
                      padding: const EdgeInsets.only(top: 8),
                      child: Text('⚠️ Confirmation requise', style: TextStyle(fontSize: 12, color: Colors.orange[700])),
                    ),
                  ],
                ),
              ),
            ),
            const SizedBox(height: 20),
            
            // 🌀 Ventilateur
            _buildSectionTitle('🌀 VENTILATEUR'),
            Card(
              child: Padding(
                padding: const EdgeInsets.all(16),
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Text('État actuel : ${fanOn ? '✅ ON' : '❌ OFF'}', style: const TextStyle(fontWeight: FontWeight.w500)),
                    const SizedBox(height: 8),
                    _buildDetailRow('Température actuelle', '24.5°C'),
                    _buildDetailRow('Seuil auto', '35°C'),
                    const SizedBox(height: 16),
                    ElevatedButton(
                      onPressed: () => setState(() => fanOn = !fanOn),
                      style: ElevatedButton.styleFrom(
                        backgroundColor: fanOn ? Colors.red : Colors.teal,
                        foregroundColor: Colors.white,
                      ),
                      child: Text(fanOn ? 'DÉSACTIVER' : 'ACTIVER'),
                    ),
                  ],
                ),
              ),
            ),
            const SizedBox(height: 20),
            
            // 💡 LEDs
            _buildSectionTitle('💡 LEDs DE CROISSANCE'),
            Card(
              child: Padding(
                padding: const EdgeInsets.all(16),
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Text('État actuel : ${ledOn ? '✅ ON' : '❌ OFF'}', style: const TextStyle(fontWeight: FontWeight.w500)),
                    const SizedBox(height: 8),
                    _buildDetailRow('Durée programmable', '6h'),
                    const SizedBox(height: 16),
                    ElevatedButton(
                      onPressed: () => setState(() => ledOn = !ledOn),
                      style: ElevatedButton.styleFrom(
                        backgroundColor: ledOn ? Colors.red : Colors.amber[700],
                        foregroundColor: Colors.white,
                      ),
                      child: Text(ledOn ? 'DÉSACTIVER' : 'ACTIVER'),
                    ),
                  ],
                ),
              ),
            ),
            const SizedBox(height: 20),
            
            // 🏖️ Mode Vacances
            _buildSectionTitle('🏖️ MODE VACANCES'),
            Card(
              color: vacationMode ? Colors.green[50] : null,
              child: Padding(
                padding: const EdgeInsets.all(16),
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Text('État : ${vacationMode ? '✅ ACTIVÉ' : '❌ DÉSACTIVÉ'}', style: const TextStyle(fontWeight: FontWeight.w500)),
                    const SizedBox(height: 8),
                    const Text('• Surveillance renforcée'),
                    const Text('• Alertes fréquentes'),
                    const SizedBox(height: 16),
                    ElevatedButton(
                      onPressed: _toggleVacationMode,
                      style: ElevatedButton.styleFrom(
                        backgroundColor: vacationMode ? Colors.orange : Colors.green[700],
                        foregroundColor: Colors.white,
                      ),
                      child: Text(vacationMode ? 'DÉSACTIVER' : 'ACTIVER LE MODE'),
                    ),
                  ],
                ),
              ),
            ),
            
            const SizedBox(height: 32),
            ElevatedButton.icon(
              onPressed: _saveChanges,
              icon: const Icon(Icons.save),
              label: const Text('💾 ENREGISTRER LES MODIFICATIONS', style: TextStyle(fontSize: 15)),
              style: ElevatedButton.styleFrom(
                backgroundColor: AppConstants.primaryGreen,
                foregroundColor: Colors.white,
                padding: const EdgeInsets.symmetric(vertical: 16),
              ),
            ),
          ],
        ),
      ),
    );
  }
  
  Widget _buildSectionTitle(String title) {
    return Padding(
      padding: const EdgeInsets.only(bottom: 12),
      child: Text(
        title,
        style: const TextStyle(fontSize: 17, fontWeight: FontWeight.bold, color: AppConstants.primaryGreen),
      ),
    );
  }
  
  Widget _buildDetailRow(String label, String value) {
    return Padding(
      padding: const EdgeInsets.symmetric(vertical: 2),
      child: Row(
        mainAxisAlignment: MainAxisAlignment.spaceBetween,
        children: [
          Text(label, style: TextStyle(color: Colors.grey[600])),
          Text(value, style: const TextStyle(fontWeight: FontWeight.w500)),
        ],
      ),
    );
  }
  
  void _confirmPump() {
    if (pumpOn) {
      setState(() => pumpOn = false);
      return;
    }
    ConfirmDialog.show(
      context: context,
      title: '⚠️ CONFIRMATION REQUISE',
      message: 'Voulez-vous vraiment activer la pompe ?',
      details: ['Durée prévue : 10 secondes', 'Consommation : ~5W', 'Dernier arrosage : Il y a 2h'],
      confirmText: '✅ OUI, ACTIVER',
      isDestructive: true,
      onConfirm: () {
        setState(() => pumpOn = true);
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(content: Text('💧 Pompe activée !'), backgroundColor: Colors.green),
        );
      },
    );
  }
  
  void _toggleVacationMode() {
    if (vacationMode) {
      setState(() => vacationMode = false);
      return;
    }
    ConfirmDialog.show(
      context: context,
      title: '🏖️ MODE VACANCES',
      message: 'Activer la surveillance renforcée ?',
      details: ['• Fréquence de mesure ×5', '• Alertes push immédiates', '• Seuils de sécurité élargis', '• Rapport d\'activité généré'],
      confirmText: '✅ ACTIVER',
      onConfirm: () {
        setState(() => vacationMode = true);
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(content: Text('🏖️ Mode vacances activé !'), backgroundColor: Colors.green),
        );
      },
    );
  }
  
  void _saveChanges() {
    ScaffoldMessenger.of(context).showSnackBar(
      const SnackBar(content: Text('✅ Modifications enregistrées !'), backgroundColor: Colors.green),
    );
  }
}
import 'package:flutter/material.dart';
import '../widgets/sensor_card.dart';
import '../widgets/actuator_card.dart';
import '../widgets/confirm_dialog.dart';
import '../utils/constants.dart';

class DashboardScreen extends StatefulWidget {
  const DashboardScreen({super.key});
  
  @override
  State<DashboardScreen> createState() => _DashboardScreenState();
}

class _DashboardScreenState extends State<DashboardScreen> {
  int _currentIndex = 0;
  
  // 📊 Données simulées des capteurs (à remplacer par API ESP32)
  final Map<String, Map<String, dynamic>> sensors = {
    'temperature': {
      'value': 24.5,
      'unit': '°C',
      'status': 'Normal',
      'threshold': '< 35°C',
      'icon': Icons.thermostat,
      'color': Colors.orange,
    },
    'humidity': {
      'value': 58,
      'unit': '%',
      'status': 'Optimal',
      'threshold': '40-70%',
      'icon': Icons.water_drop,
      'color': Colors.blue,
    },
    'soil': {
      'value': 65,
      'unit': '%',
      'status': 'Bon',
      'threshold': '> 30%',
      'icon': Icons.grass,
      'color': Colors.brown,
    },
    'light': {
      'value': 420,
      'unit': 'Lux',
      'status': 'Suffisant',
      'threshold': null,
      'icon': Icons.wb_sunny,
      'color': Colors.amber,
    },
  };
  
  // 🎛️ État des actionneurs
  final Map<String, bool> actuators = {
    'pump': false,
    'fan': false,
    'led': false,
  };
  
  // 🔄 Rafraîchir les données (simulation)
  void _refreshData() {
    setState(() {
      sensors['temperature']!['value'] = 22 + (DateTime.now().second % 10) + 0.5;
      sensors['humidity']!['value'] = 50 + (DateTime.now().second % 30);
      sensors['soil']!['value'] = 40 + (DateTime.now().second % 40);
      sensors['light']!['value'] = 300 + (DateTime.now().second % 600);
    });
    ScaffoldMessenger.of(context).showSnackBar(
      const SnackBar(content: Text('🔄 Données mises à jour !'), backgroundColor: Colors.green, duration: Duration(seconds: 2)),
    );
  }
  
  // 🎛️ Basculer un actionneur
  void _toggleActuator(String key) {
    setState(() {
      actuators[key] = !(actuators[key] ?? false);
    });
    
    // Confirmation spéciale pour la pompe
    if (key == 'pump' && actuators[key] == true) {
      ConfirmDialog.show(
        context: context,
        title: '⚠️ CONFIRMATION REQUISE',
        message: 'Voulez-vous vraiment activer la pompe ?',
        details: [
          'Durée prévue : 10 secondes',
          'Consommation : ~5W',
          'Dernier arrosage : Il y a 2h',
        ],
        confirmText: '✅ OUI, ACTIVER',
        cancelText: '❌ ANNULER',
        isDestructive: true,
        onConfirm: () {
          ScaffoldMessenger.of(context).showSnackBar(
            const SnackBar(content: Text('💧 Pompe activée !'), backgroundColor: Colors.green),
          );
        },
      );
    } else {
      final names = {'pump': 'Pompe', 'fan': 'Ventilateur', 'led': 'LEDs'};
      final state = actuators[key]! ? 'activé' : 'désactivé';
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text('${names[key]} $state !'), backgroundColor: Colors.green),
      );
    }
  }
  
  // 🚪 Ouvrir la porte (avec confirmation)
  void _openDoor() {
    ConfirmDialog.show(
      context: context,
      title: '🔐 SÉCURITÉ - OUVERTURE DE PORTE',
      message: 'Ouvrir la porte de la serre ?',
      details: [
        '✓ Authentification requise',
        '✓ Action journalisée',
        '✓ Fermeture auto dans 5s',
      ],
      confirmText: '✅ OUVRIR',
      cancelText: '❌ NON',
      onConfirm: () {
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(content: Text('🚪 Porte ouverte !'), backgroundColor: Colors.green),
        );
      },
    );
  }
  
  // 👤 Aller au profil
  void _goToProfile() {
    Navigator.pushNamed(context, '/profile');
  }
  
  // 📊 Aller à l'historique
  void _goToHistory() {
    Navigator.pushNamed(context, '/history');
  }
  
  // ⚙️ Aller aux paramètres
  void _goToSettings() {
    Navigator.pushNamed(context, '/settings');
  }
  
  // 🎛️ Aller au contrôle manuel
  void _goToControl() {
    Navigator.pushNamed(context, '/control');
  }
  
  @override
  Widget build(BuildContext context) {
    return Scaffold(
      // 🌿 Barre de Navigation Haut
      appBar: AppBar(
        title: const Text('🌿 Bloomy'),
        centerTitle: true,
        actions: [
          // 👤 Icône profil
          IconButton(
            icon: const CircleAvatar(
              backgroundColor: Colors.white24,
              child: Icon(Icons.person, size: 20, color: Colors.white),
            ),
            onPressed: _goToProfile,
            tooltip: 'Mon Profil',
          ),
          const SizedBox(width: 8),
        ],
      ),
      
      // 📱 Corps de l'écran
      body: RefreshIndicator(
        onRefresh: () async => _refreshData(),
        child: SingleChildScrollView(
          physics: const AlwaysScrollableScrollPhysics(),
          padding: const EdgeInsets.all(16),
          child: Column(
            crossAxisAlignment: CrossAxisAlignment.stretch,
            children: [
              // 📊 Section Capteurs
              Row(
                mainAxisAlignment: MainAxisAlignment.spaceBetween,
                children: [
                  const Text(
                    '📊 CAPTEURS',
                    style: TextStyle(fontSize: 18, fontWeight: FontWeight.bold, color: AppConstants.primaryGreen),
                  ),
                  IconButton(
                    icon: const Icon(Icons.refresh, size: 20),
                    onPressed: _refreshData,
                    tooltip: 'Rafraîchir',
                  ),
                ],
              ),
              const SizedBox(height: 12),
              
              // Carte : Température
              SensorCard(
                icon: sensors['temperature']!['icon'],
                title: 'TEMPÉRATURE',
                value: sensors['temperature']!['value'].toStringAsFixed(1),
                unit: sensors['temperature']!['unit'],
                status: sensors['temperature']!['status'],
                threshold: sensors['temperature']!['threshold'],
                color: sensors['temperature']!['color'],
              ),
              
              // Carte : Humidité Air
              SensorCard(
                icon: sensors['humidity']!['icon'],
                title: 'HUMIDITÉ AIR',
                value: sensors['humidity']!['value'].toStringAsFixed(1),
                unit: sensors['humidity']!['unit'],
                status: sensors['humidity']!['status'],
                threshold: sensors['humidity']!['threshold'],
                color: sensors['humidity']!['color'],
              ),
              
              // Carte : Humidité Sol
              SensorCard(
                icon: sensors['soil']!['icon'],
                title: 'HUMIDITÉ DU SOL',
                value: sensors['soil']!['value'].toStringAsFixed(1),
                unit: sensors['soil']!['unit'],
                status: sensors['soil']!['status'],
                threshold: sensors['soil']!['threshold'],
                color: sensors['soil']!['color'],
              ),
              
              // Carte : Luminosité
              SensorCard(
                icon: sensors['light']!['icon'],
                title: 'LUMINOSITÉ',
                value: sensors['light']!['value'].toStringAsFixed(0),
                unit: sensors['light']!['unit'],
                status: sensors['light']!['status'],
                threshold: sensors['light']!['threshold'],
                color: sensors['light']!['color'],
              ),
              
              const SizedBox(height: 24),
              
              // 🎛️ Section Actionneurs
              const Center(
                child: Text(
                  '──── ACTIONNEURS ────',
                  style: TextStyle(fontSize: 14, fontWeight: FontWeight.w600, color: AppConstants.textSecondary),
                ),
              ),
              const SizedBox(height: 12),
              
              // Actuateur : Pompe
              ActuatorCard(
                icon: Icons.water,
                title: '💧 Pompe d\'Arrosage',
                isOn: actuators['pump']!,
                color: Colors.blue,
                onToggle: () => _toggleActuator('pump'),
              ),
              
              // Actuateur : Ventilateur
              ActuatorCard(
                icon: Icons.air,
                title: '🌀 Ventilateur',
                isOn: actuators['fan']!,
                color: Colors.teal,
                onToggle: () => _toggleActuator('fan'),
              ),
              
              // Actuateur : LEDs
              ActuatorCard(
                icon: Icons.lightbulb,
                title: '💡 LEDs Croissance',
                isOn: actuators['led']!,
                color: Colors.amber,
                onToggle: () => _toggleActuator('led'),
              ),
              
              const SizedBox(height: 20),
              
              // 🚪 Bouton Ouvrir la Porte
              OutlinedButton.icon(
                onPressed: _openDoor,
                icon: const Icon(Icons.door_front_door, size: 20),
                label: const Text('🚪 OUVRIR LA PORTE', style: TextStyle(fontSize: 15, fontWeight: FontWeight.w500)),
                style: OutlinedButton.styleFrom(
                  foregroundColor: AppConstants.primaryGreen,
                  side: const BorderSide(color: AppConstants.primaryGreen),
                  padding: const EdgeInsets.symmetric(vertical: 14),
                ),
              ),
              
              const SizedBox(height: 20),
              
              // 🎛️ Bouton vers Contrôle Manuel
              ElevatedButton.icon(
                onPressed: _goToControl,
                icon: const Icon(Icons.settings, size: 20),
                label: const Text('🎛️ Contrôle Manuel Avancé', style: TextStyle(fontSize: 15)),
                style: ElevatedButton.styleFrom(
                  backgroundColor: AppConstants.darkGreen,
                  foregroundColor: Colors.white,
                  padding: const EdgeInsets.symmetric(vertical: 14),
                ),
              ),
              
              const SizedBox(height: 16),
              
              // 💡 Note informative
              Card(
                color: Colors.blue[50],
                child: Padding(
                  padding: const EdgeInsets.all(12),
                  child: Row(
                    children: [
                      const Icon(Icons.info_outline, color: Colors.blue, size: 20),
                      const SizedBox(width: 8),
                      Expanded(
                        child: Text(
                          'Données simulées pour le test. Connecte l\'ESP32 pour les données réelles !',
                          style: TextStyle(fontSize: 12, color: Colors.blue[900]),
                        ),
                      ),
                    ],
                  ),
                ),
              ),
            ],
          ),
        ),
      ),
      
      // 🧭 Barre de Navigation Bas
      bottomNavigationBar: BottomNavigationBar(
        currentIndex: _currentIndex,
        onTap: (index) {
          setState(() => _currentIndex = index);
          if (index == 1) _goToHistory();
          if (index == 2) _goToSettings();
          if (index == 3) _goToProfile();
        },
        type: BottomNavigationBarType.fixed,
        selectedItemColor: AppConstants.primaryGreen,
        unselectedItemColor: AppConstants.textSecondary,
        items: const [
          BottomNavigationBarItem(icon: Icon(Icons.home), label: 'Accueil'),
          BottomNavigationBarItem(icon: Icon(Icons.bar_chart), label: 'Historique'),
          BottomNavigationBarItem(icon: Icon(Icons.settings), label: 'Paramètres'),
          BottomNavigationBarItem(icon: Icon(Icons.person), label: 'Profil'),
        ],
      ),
    );
  }
}
