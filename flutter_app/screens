class HistoryScreen extends StatefulWidget {
  const HistoryScreen({super.key});
  @override
  State<HistoryScreen> createState() => _HistoryScreenState();
}

class _HistoryScreenState extends State<HistoryScreen> {
  String _selectedPeriod = '24h';
  
  List<FlSpot> get _tempData => [const FlSpot(0, 22), const FlSpot(4, 23), const FlSpot(8, 25), const FlSpot(12, 27), const FlSpot(16, 26), const FlSpot(20, 24), const FlSpot(24, 23)];
  List<FlSpot> get _soilData => [const FlSpot(0, 55), const FlSpot(4, 58), const FlSpot(8, 62), const FlSpot(12, 65), const FlSpot(16, 63), const FlSpot(20, 60), const FlSpot(24, 58)];
  
  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: const Text('← Historique des Données'), leading: IconButton(icon: const Icon(Icons.arrow_back), onPressed: () => Navigator.pop(context))),
      body: SingleChildScrollView(padding: const EdgeInsets.all(16), child: Column(crossAxisAlignment: CrossAxisAlignment.stretch, children: [
        // Sélecteur période
        Row(children: ['24h', '7 jours', '30 jours'].map((period) {
          final isSelected = _selectedPeriod == period;
          return Expanded(child: Padding(padding: const EdgeInsets.symmetric(horizontal: 4), child: FilterChip(label: Text(period), selected: isSelected, onSelected: (_) => setState(() => _selectedPeriod = period), selectedColor: AppConstants.primaryGreen.withValues(alpha: 0.2), checkmarkColor: AppConstants.primaryGreen)));
        }).toList()),
        const SizedBox(height: 24),
        
        // Graphique Température
        _buildGraphTitle('🌡️ TEMPÉRATURE ($_selectedPeriod)'),
        _buildLineChart(_tempData, '20', '40', '°C', Colors.orange),
        const SizedBox(height: 24),
        
        // Graphique Humidité Sol
        _buildGraphTitle('💧 HUMIDITÉ DU SOL ($_selectedPeriod)'),
        _buildLineChart(_soilData, '0', '100', '%', Colors.brown),
        const SizedBox(height: 24),
        
        // Graphique Humidité Air
        _buildGraphTitle('💧 HUMIDITÉ AIR ($_selectedPeriod)'),
        _buildLineChart(_soilData.map((s) => FlSpot(s.x, s.y * 0.9)).toList(), '0', '100', '%', Colors.blue),
        
        const SizedBox(height: 32),
        Row(children: [
          Expanded(child: OutlinedButton.icon(onPressed: () => ScaffoldMessenger.of(context).showSnackBar(const SnackBar(content: Text('📥 Export PDF à implémenter'))), icon: const Icon(Icons.picture_as_pdf), label: const Text('EXPORTER PDF'))),
          const SizedBox(width: 12),
          Expanded(child: ElevatedButton.icon(onPressed: () => setState(() {}), icon: const Icon(Icons.refresh), label: const Text('ACTUALISER'), style: ElevatedButton.styleFrom(backgroundColor: AppConstants.primaryGreen))),
        ]),
      ])),
    );
  }
  
  Widget _buildGraphTitle(String title) => Padding(padding: const EdgeInsets.only(bottom: 12), child: Text(title, style: const TextStyle(fontSize: 16, fontWeight: FontWeight.w600)));
  
  Widget _buildLineChart(List<FlSpot> data, String minY, String maxY, String unit, Color color) {
    return Card(child: Padding(padding: const EdgeInsets.all(16), child: SizedBox(height: 200, child: LineChart(LineChartData(
      gridData: const FlGridData(show: true, drawVerticalLine: false),
      titlesData: FlTitlesData(leftTitles: AxisTitles(sideTitles: SideTitles(showTitles: true, reservedSize: 40)), bottomTitles: AxisTitles(sideTitles: SideTitles(showTitles: true)), topTitles: const AxisTitles(sideTitles: SideTitles(showTitles: false)), rightTitles: const AxisTitles(sideTitles: SideTitles(showTitles: false))),
      borderData: FlBorderData(show: true, border: Border.all(color: Colors.grey[300]!)),
      lineBarsData: [LineChartBarData(spots: data, isCurved: true, color: color, barWidth: 3, dotData: const FlDotData(show: false), belowBarData: BarAreaData(show: true, color: color.withValues(alpha: 0.1)))],
      minY: double.parse(minY), maxY: double.parse(maxY),
    )))));
  }
}
